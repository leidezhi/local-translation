{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/main/.schemas/desktop-schema.json",
  "productName": "local-translation",
  "version": "0.1.0",
  "identifier": "com.leidezhi.local-translation",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "本地翻译",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
